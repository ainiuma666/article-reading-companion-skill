# IMA OpenAPI credentials. Do not commit real values.
IMA_OPENAPI_CLIENTID="replace-with-your-client-id"
IMA_OPENAPI_APIKEY="replace-with-your-api-key"

# Name of the IMA knowledge base that contains saved WeChat articles.
ARTICLE_DEEP_READING_SOURCE_KB="My Reading Inbox"

# Where runtime cache, logs, processed.json, and generated reader pages should live.
ARTICLE_DEEP_READING_WORKDIR="./.local"

# Optional reading-focus sources. Separate multiple paths with ":" on macOS/Linux.
ARTICLE_DEEP_READING_ATTENTION_SOURCES="./examples/attention_override.example.md"

# Optional comma-separated terms used to score candidate articles.
ARTICLE_DEEP_READING_CURATED_TERMS="AI workflow,product strategy,knowledge management"

# Optional article fetcher path. Leave empty if `wechat-article-to-markdown` is on PATH.
WECHAT_ARTICLE_TO_MARKDOWN=""

# Optional tuning.
ARTICLE_DEEP_READING_MIN_BODY_CHARS="1000"
ARTICLE_DEEP_READING_MAX_FETCH_ATTEMPTS="8"
ARTICLE_DEEP_READING_SHORTLIST_LIMIT="15"

